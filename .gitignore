# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python (MCP server + agent virtualenvs / caches)
**/.venv/
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/*.egg-info/

# RSA signing keys (regenerated per environment)
project_2/keys/*.pem
project_2/service-account.json

# local scratch / debug artifacts (not part of the project)
/.tmp/
/design/
hash-out*.txt
findings.md
gemini.md
progress.md
task_plan.md
sync-karma.mjs
test-*.js
test-*.mjs
*.log
